<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/root_view"
  style="@style/root_view"
  >
  <TextView android:id="@+id/title"
    style="@style/text_title"
  />
<!-- ScrollView xmlns:android="http://schemas.android.com/apk/res/android" 
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:orientation="vertical"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_below="@id/title"
  >
 
  <CheckBox android:id="@+id/shots"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:checked="true"
    android:text="@string/flip_shots"
  />
  <CheckBox android:id="@+id/scrap"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:checked="true"
    android:text="@string/mode_scrap"
  />

  <LinearLayout android:id="@+id/help"
      style="@style/help_layout"
    >
    <Button android:id="@+id/button_help"
      style="@style/button_empty"
      android:text="@string/button_help"
      android:layout_marginRight="@dimen/marginh"
    />
    <Button android:id="@+id/button_close"
      style="@style/button_default"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/button_cancel"
      android:layout_marginRight="@dimen/marginh"
    />
    <LinearLayout 
      android:layout_width="fill_parent" 
      android:layout_height="wrap_content"
      android:gravity="end"
      >
      <Button android:id="@+id/button_ok"
        android:layout_height="match_parent"
        style="@style/button_default"
        android:text="@string/button_ok"
        android:layout_gravity="end"
      />
    </LinearLayout>
  </LinearLayout>
  </LinearLayout>
  <!-- /ScrollView -->
</RelativeLayout>
