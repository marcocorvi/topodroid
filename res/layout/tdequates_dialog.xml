<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/root_view"
  style="@style/root_view"
  >
  <TextView android:id="@+id/title"
    style="@style/text_title"
  />
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:layout_margin="10dp"
    android:layout_below="@id/title"
    >
    <ListView android:id="@+id/list"
      style="@style/list_top_fast"
      android:layout_marginTop="10dp"
      android:padding="10dp"
      android:layout_width="fill_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
    />  
    <!-- android:layout_height="fill_parent" -->

    <LinearLayout android:id="@+id/help"
      style="@style/help_layout"
      >
      <Button android:id="@+id/button_help"
        style="@style/button_empty"
        android:text="@string/button_help"
        android:layout_marginEnd="@dimen/marginh"
      />
      <Button android:id="@+id/button_cancel"
        style="@style/button_default"
        android:layout_marginEnd="@dimen/marginh"
        android:text="@string/button_cancel"
      />
      <LinearLayout
        android:layout_width="fill_parent" 
        android:layout_height="wrap_content"
        android:gravity="end"
        >
        <Button android:id="@+id/button_clear"
          style="@style/button_default"
          android:layout_marginEnd="@dimen/marginh"
          android:text="@string/button_clear_all"
        />
        <!-- Button android:id="@+id/button_add"
          style="@style/button_default"
          android:layout_marginEnd="@dimen/marginh"
          android:text="@string/button_add"
        / -->
      </LinearLayout>
    </LinearLayout>

  </LinearLayout>

</RelativeLayout>
