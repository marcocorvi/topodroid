<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/root_view"
  style="@style/root_view"
  >
  <TextView android:id="@+id/title"
    style="@style/text_title"
  />
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  style="@style/base_padding"
  android:layout_width="match_parent" 
  android:layout_height="fill_parent"
  android:orientation="vertical"
  android:layout_below="@id/title"
  >
  <LinearLayout android:id="@+id/help"
      style="@style/help_layout"
    >
    <Button android:id="@+id/button_help"
      style="@style/button_empty"
      android:text="@string/button_help"
      android:layout_marginEnd="@dimen/marginh"
    />
      <Button android:id="@+id/code_cancel"
        style="@style/button_default"
        android:text="@string/button_cancel"
        android:layout_marginEnd="@dimen/marginh"
      />
    <LinearLayout 
      android:layout_width="fill_parent" 
      android:layout_height="wrap_content"
      android:gravity="end"
      >
      <Button android:id="@+id/code_ok"
        style="@style/button_default"
        android:text="@string/button_ok"
      />
    </LinearLayout>
  </LinearLayout>

  <ListView android:id="@+id/code_list"
     style="@style/list_top"
     android:layout_width="match_parent"
     android:layout_height="fill_parent" 
     android:layout_weight="1"
     android:background="#111"
  />
  <!-- lint: Use a layout_height of 0dp instead of fill_parent for better performance -->
</LinearLayout>
</RelativeLayout>
