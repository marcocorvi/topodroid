<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/root_view"
  style="@style/root_view"
  >
  <TextView android:id="@+id/title"
    style="@style/text_title"
  />
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" 
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_below="@id/title"
    >
    <LinearLayout 
      style="@style/base_padding"
      android:layout_width="wrap_content" 
      android:layout_height="wrap_content"
      android:orientation="vertical"
      >
      <TextView android:id="@+id/coeff_bg"
          android:layout_marginTop="@dimen/margintiny"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content" 
          android:text="@string/b_g"
      />
      <TextView android:id="@+id/coeff_agx"
          android:layout_marginTop="@dimen/margintiny"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content" 
          android:text="@string/a_gx"
      />
      <TextView android:id="@+id/coeff_agy"
          android:layout_marginTop="@dimen/margintiny"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content" 
          android:text="@string/a_gy"
      />
      <TextView android:id="@+id/coeff_agz"
          android:layout_marginTop="@dimen/margintiny"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content" 
          android:text="@string/a_gz"
      />
      <TextView android:id="@+id/coeff_bm"
          android:layout_marginTop="@dimen/margintiny"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content" 
          android:text="@string/b_m"
      />
      <TextView android:id="@+id/coeff_amx"
          android:layout_marginTop="@dimen/margintiny"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content" 
          android:text="@string/a_mx"
      />
      <TextView android:id="@+id/coeff_amy"
          android:layout_marginTop="@dimen/margintiny"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content" 
          android:text="@string/a_my"
      />
      <TextView android:id="@+id/coeff_amz"
          android:layout_marginTop="@dimen/margintiny"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content" 
          android:text="@string/a_mz"
      />
      <TextView android:id="@+id/coeff_nl"
          android:layout_marginTop="@dimen/margintiny"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content" 
          android:text="@string/nl_g"
      />
    </LinearLayout>
  
    <LinearLayout android:id="@+id/help"
      style="@style/help_layout"
      >
      <Button android:id="@+id/button_help"
        style="@style/button_empty"
        android:text="@string/button_help"
        android:layout_marginRight="@dimen/marginh"
      />
      <Button android:id="@+id/button_close"
        style="@style/button_default"
        android:text="@string/button_cancel"
      />
      <LinearLayout 
        android:layout_width="fill_parent" 
        android:layout_height="wrap_content"
        android:gravity="end"
        >
        <Button android:id="@+id/button_write"
          style="@style/button_default"
          android:text="@string/button_write"
        />
        <!-- Button android:id="@+id/button_stop"
          style="@style/button_default"
          android:text="@string/button_stop"
        / -->
        <Button android:id="@+id/button_start"
          style="@style/button_default"
          android:text="@string/button_start"
        />
      </LinearLayout>
    </LinearLayout>
  
  </LinearLayout>
</RelativeLayout>
