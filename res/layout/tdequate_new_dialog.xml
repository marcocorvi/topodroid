<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/root_view"
  style="@style/root_view"
  >
  <TextView android:id="@+id/title"
    style="@style/text_title"
  />
  <!-- ScrollView xmlns:android="http://schemas.android.com/apk/res/android" 
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    -->
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" 
    android:layout_width="fill_parent" 
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_below="@id/title"
    android:paddingStart="6dp"
    android:paddingEnd="6dp"
    android:paddingBottom="3dp">

    <LinearLayout android:id="@+id/layout4"
      android:layout_width="fill_parent" 
      android:layout_height="wrap_content"
      android:orientation="vertical" 
      android:layout_marginTop="25dp" 
      android:gravity="start"
      >
    </LinearLayout>
   		
    <LinearLayout android:id="@+id/help"
      style="@style/help_layout"
      >
      <Button android:id="@+id/button_help"
        style="@style/button_empty"
        android:text="@string/button_help"
        android:layout_marginEnd="@dimen/marginh"
      />
        <Button android:id="@+id/button_cancel"
          style="@style/button_default"
          android:layout_marginEnd="@dimen/marginh"
          android:text="@string/button_cancel"
        />
      <LinearLayout
        android:layout_width="fill_parent" 
        android:layout_height="wrap_content"
        android:gravity="end"
        >
        <!-- HB EQ all-->
          <Button android:id="@+id/button_search"
              style="@style/button_default"
              android:layout_marginEnd="@dimen/marginh"
              android:text="@string/button_equate_search"
              />
           <Button android:id="@+id/button_one"
              style="@style/button_default"
              android:layout_marginEnd="@dimen/marginh"
              android:text="@string/button_equate_one"
              />
          <Button android:id="@+id/button_all"
              style="@style/button_default"
              android:layout_marginEnd="@dimen/marginh"
              android:text="@string/button_equate_all"
              />
        <!-- HB EQ all-->
        <Button android:id="@+id/button_ok"
          style="@style/button_default"
          android:layout_marginEnd="@dimen/marginh"
          android:text="@string/button_ok"
        />
      </LinearLayout>
    </LinearLayout>
   		
  </LinearLayout>
  <!-- /ScrollView -->
</RelativeLayout>
