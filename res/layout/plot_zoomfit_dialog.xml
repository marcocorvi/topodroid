<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/root_view"
  style="@style/root_view"
  >
  <TextView android:id="@+id/title"
    style="@style/text_title"
  />
  <!-- ScrollView xmlns:android="http://schemas.android.com/apk/res/android" 
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    -->
<LinearLayout android:id="@+id/layout0"
  android:orientation="vertical"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
    android:layout_below="@id/title"
  >
   
  <!-- Button android:id="@+id/button_zoomfit"
    style="@style/button_default"
    android:text="@string/button_zoomfit"
    / -->

  <LinearLayout android:id="@+id/layout_orientation"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" 
    android:layout_marginTop="10pt" 
    android:layout_marginBottom="10pt" 
    >

    <!-- Button android:id="@+id/button_portrait"
      style="@style/button_default"
      android:text="@string/button_portrait"
    / -->

    <!-- Button android:id="@+id/button_landscape"
      style="@style/button_default"
      android:text="@string/button_landscape"
    / -->
  </LinearLayout>

  <!-- FIXED_ZOOM -->
  <LinearLayout android:id="@+id/layout_zoom"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" 
    android:layout_marginTop="10pt" 
    android:layout_marginBottom="10pt" 
    >

    <Button android:id="@+id/button_zoom"
      style="@style/button_default"
      android:text="@string/zoom_fixed"
    />

    <!-- CheckBox android:id="@+id/cb_zoom"
    / -->

    <Spinner android:id="@+id/spin_zoom"
      android:layout_width="fill_parent"
      android:layout_height="wrap_content" 
    />
  </LinearLayout>
  <!-- END FIXED_ZOOM -->

  <LinearLayout android:id="@+id/layout_station"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content" 
    android:layout_marginTop="10pt" 
    android:layout_marginBottom="10pt" 
    >
    <Button android:id="@+id/button_clear_station"
      style="@style/button_default"
      android:text="@string/button_clear"
      />
    <Button android:id="@+id/button_center_station"
      style="@style/button_default"
      android:text="@string/button_station"
      />
    <EditText android:id="@+id/center_station"
      android:layout_width="match_parent"
      android:layout_height="wrap_content" 
      android:layout_marginStart="10pt" 
      android:inputType="text"
      android:hint="@string/hint_station"
      android:importantForAutofill="no"
      />
  </LinearLayout>

  <LinearLayout android:id="@+id/help"
    style="@style/help_layout"
    >
    <Button android:id="@+id/button_help"
        style="@style/button_empty"
        android:text="@string/button_help"
        android:layout_marginEnd="@dimen/marginh"
    />
    <Button android:id="@+id/button_cancel"
      style="@style/button_default"
      android:text="@string/button_cancel"
      android:layout_marginEnd="@dimen/marginh"
    />
    <!-- LinearLayout 
      android:layout_width="fill_parent" 
      android:layout_height="wrap_content"
      android:gravity="end"
      >
    </LinearLayout -->
  </LinearLayout>

  </LinearLayout>
  <!-- /ScrollView -->
</RelativeLayout>
