<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/root_view"
  style="@style/root_view"
  >
  <TextView android:id="@+id/title"
    style="@style/text_title"
  />
  <!-- ScrollView xmlns:android="http://schemas.android.com/apk/res/android" 
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    -->
<LinearLayout
  style="@style/base_padding"
  android:layout_width="match_parent" 
  android:layout_height="wrap_content"
  android:orientation="vertical"
    android:layout_below="@id/title"
  >

  <Spinner android:id="@+id/spin"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/marginvbig"
    android:drawSelectorOnTop="true"
  />
      				  
  <LinearLayout android:id="@+id/help"
    style="@style/help_layout"
    >
    <Button android:id="@+id/button_help"
        style="@style/button_empty"
        android:text="@string/button_help"
        android:layout_marginEnd="@dimen/marginh"
    />
      <Button android:id="@+id/button_cancel"
        style="@style/button_default"
        android:text="@string/button_cancel"
        android:layout_marginEnd="@dimen/marginh"
      />
    <LinearLayout
      android:layout_width="fill_parent" 
      android:layout_height="wrap_content"
      android:gravity="end"
      >
      <Button android:id="@+id/button_split"
        style="@style/button_default"
        android:text="@string/button_split"
        android:textColor="@color/textdelete"
        android:layout_marginEnd="@dimen/marginh"
      />
      <Button android:id="@+id/button_move"
        style="@style/button_default"
        android:text="@string/button_move"
        android:textColor="@color/textdelete"
        android:layout_marginEnd="@dimen/marginh"
      />
    </LinearLayout>
  </LinearLayout>
   		
  </LinearLayout>
  <!-- /ScrollView -->
</RelativeLayout>
