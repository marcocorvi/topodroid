<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/root_view"
  style="@style/root_view"
  >
  <TextView android:id="@+id/title"
    style="@style/text_title"
  />
  <!-- ScrollView xmlns:android="http://schemas.android.com/apk/res/android" 
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    -->
  <LinearLayout 
    android:layout_width="fill_parent" 
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_below="@id/title"
    android:paddingStart="6dip"
    android:paddingEnd="6dip"
    android:paddingBottom="3dip"
    >

    <CheckBox android:id="@+id/surface"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_margin="10dp"
      android:text="@string/legs_surface"
    />

    <CheckBox android:id="@+id/duplicate"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_margin="10dp"
      android:text="@string/legs_duplicate"
    />

    <CheckBox android:id="@+id/commented"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_margin="10dp"
      android:text="@string/legs_commented"
    />

    <CheckBox android:id="@+id/backshot"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_margin="10dp"
      android:text="@string/legs_backshot"
    />


  <LinearLayout android:id="@+id/help"
    style="@style/help_layout"
    > 
    <!-- android:layout_below="@id/commented" -->
    <Button android:id="@+id/button_help"
      style="@style/button_empty"
      android:text="@string/button_help"
      android:layout_marginRight="@dimen/marginh"
    />
    <Button android:id="@+id/button_cancel"
      style="@style/button_default"
      android:layout_width="wrap_content" 
      android:layout_height="wrap_content"
      android:text="@string/button_cancel"
    />
    <LinearLayout
        android:layout_width="fill_parent" 
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="end"
        android:layout_marginTop="20dp"
        >
        <Button android:id="@+id/button_ok"
          style="@style/button_default"
          android:layout_width="wrap_content" 
          android:layout_height="wrap_content"
          android:text="@string/button_ok"
        />
      </LinearLayout>
    </LinearLayout>
  </LinearLayout>
  <!-- /ScrollView -->
</RelativeLayout>
